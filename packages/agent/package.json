{
  "name": "@conduit/agent",
  "version": "0.0.0",
  "private": true,
  "description": "Agent provider abstraction, workspace manager, MCP config resolver, skill discovery for Conduit.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./provider": {
      "types": "./dist/provider/index.d.ts",
      "default": "./dist/provider/index.js"
    },
    "./workspace": {
      "types": "./dist/workspace/index.d.ts",
      "default": "./dist/workspace/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "default": "./dist/mcp/index.js"
    },
    "./skill": {
      "types": "./dist/skill/index.d.ts",
      "default": "./dist/skill/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@conduit/shared": "0.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
