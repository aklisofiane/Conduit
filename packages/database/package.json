{
  "name": "@conduit/database",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema and client for Conduit.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "db:push": "prisma db push --skip-generate && prisma generate",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --skip-generate --skip-seed"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "prisma": "^6.2.1",
    "typescript": "^5.7.3"
  }
}
