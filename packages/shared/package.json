{
  "name": "@conduit/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared types and Zod schemas for Conduit (workflows, agents, triggers, MCP, runtime events).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./platform": {
      "types": "./dist/platform/index.d.ts",
      "default": "./dist/platform/index.js"
    },
    "./trigger": {
      "types": "./dist/trigger/index.d.ts",
      "default": "./dist/trigger/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "default": "./dist/mcp/index.js"
    },
    "./workspace": {
      "types": "./dist/workspace/index.d.ts",
      "default": "./dist/workspace/index.js"
    },
    "./skill": {
      "types": "./dist/skill/index.d.ts",
      "default": "./dist/skill/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "default": "./dist/agent/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "default": "./dist/workflow/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
