{
  "name": "@conduit/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared types and Zod schemas for Conduit (workflows, agents, triggers, MCP, runtime events).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./platform": {
      "types": "./src/platform/index.ts",
      "default": "./src/platform/index.ts"
    },
    "./trigger": {
      "types": "./src/trigger/index.ts",
      "default": "./src/trigger/index.ts"
    },
    "./mcp": {
      "types": "./src/mcp/index.ts",
      "default": "./src/mcp/index.ts"
    },
    "./workspace": {
      "types": "./src/workspace/index.ts",
      "default": "./src/workspace/index.ts"
    },
    "./skill": {
      "types": "./src/skill/index.ts",
      "default": "./src/skill/index.ts"
    },
    "./agent": {
      "types": "./src/agent/index.ts",
      "default": "./src/agent/index.ts"
    },
    "./workflow": {
      "types": "./src/workflow/index.ts",
      "default": "./src/workflow/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "default": "./src/runtime/index.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
