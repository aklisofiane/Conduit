  "private": true,
  "description": "Conduit Temporal worker: agentWorkflow + activities that invoke agent providers.",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
