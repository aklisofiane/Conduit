{
  "name": "conduit",
  "version": "0.0.0",
  "private": true,
  "description": "Agent-first workflow automation for dev teams.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:api": "vitest run --project api",
    "pretest:e2e": "turbo run build --filter=@conduit/api --filter=@conduit/worker",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yaml,yml}\"",
    "db:push": "dotenv -e .env -- npm --workspace @conduit/database run db:push",
    "db:generate": "dotenv -e .env -- npm --workspace @conduit/database run db:generate",
    "db:studio": "dotenv -e .env -- npm --workspace @conduit/database run db:studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "test:infra:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:infra:down": "docker compose -f docker-compose.test.yml down -v",
    "test:infra:logs": "docker compose -f docker-compose.test.yml logs -f"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@temporalio/testing": "^1.16.0",
    "@types/node": "^22.10.5",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
