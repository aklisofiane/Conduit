# ----- Database -----
# Postgres from docker-compose.yml (port 5434 to avoid collision with a local 5432).
DATABASE_URL="postgresql://conduit:conduit@localhost:5434/conduit?schema=public"

# ----- Temporal -----
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"
TEMPORAL_TASK_QUEUE="conduit-agents"

# ----- Redis -----
REDIS_URL="redis://localhost:6379"

# ----- API -----
API_PORT=3001
# Single API key protects non-webhook routes. Generate a random string.
API_KEY="dev-api-key-change-me"
# Dev-only webhook escape hatch (accepts this value as any signature). Leave empty in prod.
WEBHOOK_DEV_SECRET=""

# ----- Web -----
# Vite reads VITE_*; keep these prefixed.
VITE_API_URL="http://localhost:3001"
VITE_WS_URL="ws://localhost:3001"

# ----- Worker / providers -----
# Which agent provider adapter to load. "claude" | "codex" | "stub" (Phase 1.5+).
CONDUIT_PROVIDER="claude"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# AES-256-GCM key for PlatformCredential.secret (SECURITY.md). Leave empty on single-host dev
# to auto-generate ~/.conduit/key; set explicitly when DB and app run on different hosts.
CONDUIT_ENCRYPTION_KEY=""
